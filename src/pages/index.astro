---
import PageNav from '../components/PageNav.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';
import profile from '../data/profile.js';
import '../styles/global.css';

const pageTitle = `${profile.name} | Portfolio`;
const pageDescription =
  'Portfolio editorial de Jesús Cervantes Fernández, desarrollador fullstack con interés en desarrollo web, apps multiplataforma, videojuegos e inteligencia artificial.';
const faviconHref = `${import.meta.env.BASE_URL.replace(/\/?$/, '/') }favicon.svg`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <div class="page-shell">
      <PageNav />
      <div class="page-shell__content">
        <main id="contenido" class="site-main">
          <Hero />
          <Projects />
          <About />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
