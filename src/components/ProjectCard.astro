---
const { project } = Astro.props;
const assetBase = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const projectImageSrc = project.image
  ? `${assetBase}${project.image.replace(/^\/+/, '')}`
  : undefined;
const cardLabel = project.featured ? 'Proyecto destacado' : 'Exploración técnica';
---

<article class:list={['project-card', project.featured && 'project-card--featured']}>
  {
    project.image && (
      <div class="project-card__media">
        <img
          class="project-card__image"
          src={projectImageSrc}
          alt={project.imageAlt ?? `Imagen del proyecto ${project.name}`}
          loading="lazy"
        />
      </div>
    )
  }

  <div class="project-card__body">
    <div class="project-card__content">
      <div class="project-card__header">
        <p class="project-card__label">{cardLabel}</p>
        <h3>{project.name}</h3>
        {project.context && <p class="project-card__context">{project.context}</p>}
      </div>

      <p class="project-card__description">{project.description}</p>

      <ul class="tag-list" aria-label={`Tecnologías y áreas de ${project.name}`}>
        {project.tags.map((tag) => <li>{tag}</li>)}
      </ul>
    </div>

    <div class="project-card__actions">
      <a class="project-card__link" href={project.repoUrl} target="_blank" rel="noreferrer">
        Ver repositorio
      </a>

      {project.landingUrl && (
        <a class="project-card__link" href={project.landingUrl} target="_blank" rel="noreferrer">
          Ver landing page
        </a>
      )}
    </div>
  </div>
</article>
